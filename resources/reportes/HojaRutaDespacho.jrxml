<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="HojaRutaDespacho"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="b2c3d4e5-f6a7-8901-bcde-f12345678901">
    <parameter name="VIAJE_ID" class="java.lang.Integer">
        <defaultValueExpression><![CDATA[1]]></defaultValueExpression>
    </parameter>
    <queryString>
        <![CDATA[SELECT
            vi.id AS viaje_id,
            ve.placa,
            ve.marca,
            CONCAT(e.nombre, ' ', e.apellido) AS chofer_nombre,
            e.telefono AS chofer_telefono,
            vi.ruta,
            vi.es_redondo,
            vi.kilometros,
            vi.litros_estimados,
            vi.gasto_combustible,
            vi.fecha_salida,
            COALESCE((
                SELECT GROUP_CONCAT(CONCAT(h.codigo, ' - ', h.nombre) SEPARATOR ', ')
                FROM herramienta h
                WHERE h.empleado_id = vi.chofer_id AND h.estado = 'ASIGNADA'
            ), 'Sin herramientas asignadas') AS herramientas_custodia
        FROM viaje vi
        INNER JOIN vehiculo ve ON vi.vehiculo_id = ve.id
        INNER JOIN empleado e ON vi.chofer_id = e.id
        WHERE vi.id = $P{VIAJE_ID}]]>
    </queryString>
    <field name="viaje_id" class="java.lang.Integer"/>
    <field name="placa" class="java.lang.String"/>
    <field name="marca" class="java.lang.String"/>
    <field name="chofer_nombre" class="java.lang.String"/>
    <field name="chofer_telefono" class="java.lang.String"/>
    <field name="ruta" class="java.lang.String"/>
    <field name="es_redondo" class="java.lang.Boolean"/>
    <field name="kilometros" class="java.lang.Integer"/>
    <field name="litros_estimados" class="java.math.BigDecimal"/>
    <field name="gasto_combustible" class="java.math.BigDecimal"/>
    <field name="fecha_salida" class="java.sql.Timestamp"/>
    <field name="herramientas_custodia" class="java.lang.String"/>
